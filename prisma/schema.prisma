generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DEVELOPER
  BASKAN
  BASKAN_YARDIMCISI
  YONETICI
  NORDIAN
  UYE
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?
  passwordHash  String
  name          String
  callsign      String?          @unique
  region        String?
  bio           String?
  weapons       String?
  avatarUrl     String?
  role          Role             @default(UYE)
  status        MembershipStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([role])
  @@index([status])
}
