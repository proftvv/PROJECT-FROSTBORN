generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 6 kademeli rütbe modeli ──
enum Role {
  DEVELOPER // Seviye 6 — sistemin tamamı
  BASKAN // Seviye 5 — tüm yetkiler
  BASKAN_YARDIMCISI // Seviye 5 — başkanla eşdeğer
  YONETICI // Seviye 4 — admin paneli
  NORDIAN // Seviye 3 — takım oyuncusu
  UYE // Seviye 2 — normal üye
}

enum MembershipStatus {
  PENDING // Başvuru bekliyor
  ACTIVE // Aktif üye
  SUSPENDED // Askıya alınmış
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  name          String
  callsign      String?   @unique
  region        String?
  role          Role      @default(UYE)
  status        MembershipStatus @default(PENDING)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  verificationCodes VerificationCode[]
  applications      Application[]
  announcements     Announcement[]
  teamContents      TeamContent[]
  chatMessages      ChatMessage[]

  @@index([role])
  @@index([status])
}

// E-posta doğrulama & şifre sıfırlama kodları
enum CodePurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model VerificationCode {
  id        String      @id @default(cuid())
  userId    String
  code      String
  purpose   CodePurpose
  expiresAt DateTime
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
}

// ── VALHALLA: Panel modelleri ──

enum ApplicationStatus {
  PENDING // İncelenmedi
  APPROVED // Onaylandı
  REJECTED // Reddedildi
}

// Takıma katılım başvurusu
model Application {
  id         String            @id @default(cuid())
  userId     String
  region     String
  experience String // Airsoft deneyimi
  motivation String // Neden katılmak istiyor
  status     ApplicationStatus @default(PENDING)
  reply      String? // Yönetim yanıtı
  repliedBy  String? // Yanıtlayan kullanıcı id
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Duyurular
model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  minLevel  Int      @default(2) // Bu seviye ve üstü görür
  authorId  String
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([minLevel])
}

enum ContentType {
  MAP // Saha haritası / kroki
  TRAINING // Eğitim içeriği
}

// Nordian'a özel içerikler (haritalar + eğitimler)
model TeamContent {
  id          String      @id @default(cuid())
  type        ContentType
  title       String
  description String
  url         String? // Dosya/video bağlantısı
  authorId    String
  createdAt   DateTime    @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([type])
}

// Takım içi sohbet (Nordian ve üstü)
model ChatMessage {
  id        String   @id @default(cuid())
  body      String
  authorId  String
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}
